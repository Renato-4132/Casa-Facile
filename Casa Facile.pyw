        text_area.pack(fill="both", expand=True)
        def save_file():
            now = datetime.date.today()
            fname = f"Report_Export_{now.day:02d}-{now.month:02d}-{now.year}.txt"
            file = filedialog.asksaveasfilename(
                defaultextension=".txt", 
