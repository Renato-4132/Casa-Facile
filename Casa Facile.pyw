                            ("Per aumentare massa (+10%)",     round(base_kcal * 1.10),  (0.1, 0.6, 0.2)),
                        ]
                        _tx(page, "Obiettivi Consigliati", ML, cy, fs=10, col=GREEN2, bold=True)
                        cy += 14
                        for desc, kcal, col2 in obiettivi_cal:
