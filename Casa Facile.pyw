    def scarica_manuale_ssl(self):
        try:
            response = requests.get(URL_PDF_SSL, timeout=15)
            response.raise_for_status()
            temp_path = os.path.join(tempfile.gettempdir(), "manuale_ssl.pdf")
            with open(temp_path, "wb") as f:
