def show_warning_name_popup():
    splash = tk.Tk()
    splash.overrideredirect(True)
    width, height = 380, 120
    x = (splash.winfo_screenwidth() // 2) - (width // 2)
    y = (splash.winfo_screenheight() // 2) - (height // 2)
    splash.geometry(f"{width}x{height}+{x}+{y}")
    splash.configure(bg="#000000", highlightthickness=2, highlightbackground="#61AFEF")
    label = tk.Label(
        splash,
        text=f"Nome Cartella Troppo Lungo !\n Rinomina la cartella e Rilancia l'App",
        font=("Arial", 12, "bold"),
        fg="#61AFEF",
        bg="#000000",
        justify="center",
        padx=10,
        pady=10
    )
    label.pack(expand=True, fill="both")
    splash.after(4000, splash.destroy)
    splash.attributes("-topmost", True)
    splash.mainloop()

# Nome cartella Massimo Caratteri
