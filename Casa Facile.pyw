                            xc += w3
                        cy += 18
                        RH_PED = 16
                        for i, (data_str, rec) in enumerate(voci_ordinate):
                            if cy + RH_PED > PAGE_H - MB - 20:
                                fy3 = PAGE_H - MB + 8
                                page.draw_line(fitz.Point(ML, fy3 - 4), fitz.Point(PAGE_W - MR, fy3 - 4),
