            giorno_v = tk.StringVar(value=giorno_nome)
            def _aggiorna_giorni(*_):
                idx = sett_nomi.index(sett_v.get())
                nomi = [r[0] for r in piano_dati[idx]["giorni"]]
                cb_giorno["values"] = nomi
                if giorno_v.get() not in nomi:
