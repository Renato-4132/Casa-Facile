        def _log(msg):
            txt.config(state=tk.NORMAL)
            txt.insert(tk.END, msg + "\n")
            txt.see(tk.END)
            txt.config(state=tk.DISABLED)
        def _riavvia(e=None):
            self.show_toast("Riavvio In Corso !", duration=3000)
            def esegui_kill():
                if popup.winfo_exists():
                    popup.destroy()
                script_path = os.path.abspath(sys.argv[0])
                args = [sys.executable, script_path] + sys.argv[1:]
                if os.name == 'nt':
                    subprocess.Popen(args, creationflags=0x00000008, shell=False, close_fds=True)
                else:
                    subprocess.Popen(args, start_new_session=True, close_fds=True)
                self.destroy()
                os._exit(0)
            self.after(800, esegui_kill)
        def _abilita_riavvia():
            btn_riavvia.config(cursor="hand2")
            btn_riavvia.bind("<Button-1>", _riavvia)
        def _esegui():
            btn_avvia.config(cursor="X_cursor")
            btn_avvia.unbind("<Button-1>")
            selezionate = [(pkg, var) for pkg, var in vars_lib if var.get()]
            if not selezionate:
                self.after(0, lambda: _log("⚠️ Nessuna libreria selezionata."))
                self.after(0, lambda: btn_avvia.config(cursor="hand2", fg=self.TEXT_COLOR))
                self.after(0, lambda: btn_avvia.bind("<Button-1>", lambda e: threading.Thread(target=_esegui, daemon=True).start()))
                return
            self.after(0, lambda: _log(f"Avvio aggiornamento {len(selezionate)} librerie...\n"))
            errori = 0
            for pkg, _ in selezionate:
                self.after(0, lambda l=pkg: _log(f"⏳ {l}..."))
                try:
                    result = subprocess.run(
                        [sys.executable, "-m", "pip", "install", "-U", pkg, "--break-system-packages"],
                        capture_output=True, text=True, timeout=120
                    )
                    if result.returncode == 0:
                        self.after(0, lambda l=pkg: _log(f"✓ {l} aggiornato"))
                    else:
                        errori += 1
                        err = result.stderr.strip().splitlines()[-1] if result.stderr.strip() else "errore"
                        self.after(0, lambda l=pkg, e=err: _log(f"⚠️ {l}: {e[:80]}"))
                except subprocess.TimeoutExpired:
                    errori += 1
                    self.after(0, lambda l=pkg: _log(f"❌ {l}: timeout"))
                except Exception as ex:
                    errori += 1
                    self.after(0, lambda l=pkg, e=str(ex): _log(f"❌ {l}: {e}"))
            msg = f"\n✅ Completato. {len(selezionate)-errori} ok, {errori} errori." if errori else "\n✅ Completato. Tutte le librerie aggiornate."
            self.after(0, lambda: _log(msg))
            self.after(0, _abilita_riavvia)
        btn_avvia.bind("<Button-1>", lambda e: threading.Thread(target=_esegui, daemon=True).start())

    # Portafoglio — Investimenti
    def _porta_load(self):
        import json, os
        if not os.path.exists(PORTAFOGLIO_FILE):
            return {"impostazioni": {"valuta": "EUR", "soglia_ribilanciamento": 2.0},
                    "titoli": []}
        try:
            with open(PORTAFOGLIO_FILE, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception:
            return {"impostazioni": {"valuta": "EUR", "soglia_ribilanciamento": 2.0},
                    "titoli": []}
    def _porta_save(self, dati):
        import json, os
        os.makedirs(DB_DIR, exist_ok=True)
        with open(PORTAFOGLIO_FILE, "w", encoding="utf-8") as f:
            json.dump(dati, f, indent=2, ensure_ascii=False)
    def _porta_prezzo_live(self, ticker):
        try:
            import yfinance as yf
            import logging, os, io, contextlib
            logging.getLogger("yfinance").setLevel(logging.CRITICAL)
            t = yf.Ticker(ticker)
            with contextlib.redirect_stdout(io.StringIO()), \
                 contextlib.redirect_stderr(io.StringIO()):
                h = t.history(period="1d")
            if not h.empty:
                return float(h["Close"].iloc[-1])
        except Exception:
            pass
            return None
    def _porta_calcola_titolo(self, t, prezzo_live=None):
        movimenti = t.get("movimenti", [])
        quantita  = 0.0
        costo_tot = 0.0
        for m in movimenti:
            q = float(m.get("quantita", 0))
            p = float(m.get("prezzo", 0))
            c = float(m.get("commissioni", 0))
            if m.get("tipo") == "acquisto":
                quantita  += q
                costo_tot += q * p + c
            elif m.get("tipo") == "vendita":
                if quantita > 0:
                    pmc = costo_tot / quantita if quantita else 0
                    quantita  -= q
                    costo_tot -= q * pmc
        quantita  = max(quantita, 0.0)
        costo_tot = max(costo_tot, 0.0)
        pmc       = (costo_tot / quantita) if quantita > 0 else 0.0
        dividendi_netti = sum(float(d.get("importo_netto", d.get("importo", 0)))
                              for d in t.get("dividendi", []))
        prezzo = prezzo_live if prezzo_live is not None else float(t.get("ultimo_prezzo", 0))
        valore_attuale = quantita * prezzo
        pl_eur  = valore_attuale - costo_tot
        pl_pct  = (pl_eur / costo_tot * 100) if costo_tot > 0 else 0.0
        return {
            "ticker":          t["ticker"],
            "descrizione":     t.get("descrizione", ""),
            "asset_class":     t.get("asset_class", "-"),
            "target_pct":      float(t.get("target_pct", 0)),
            "quantita":        quantita,
            "pmc":             pmc,
            "prezzo_attuale":  prezzo,
            "valore_attuale":  valore_attuale,
            "investito":       costo_tot,
            "pl_eur":          pl_eur,
            "pl_pct":          pl_pct,
            "dividendi_netti": dividendi_netti,
        }
