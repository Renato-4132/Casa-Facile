                return
            try: imp_corrente = float(val)
            except ValueError: return
            import datetime
            oggi = datetime.date.today()
            un_anno_fa = oggi - datetime.timedelta(days=365)
            mappa_ricorrenti = {}
            for d, lista in self.spese.items():
                if d < un_anno_fa: continue
                for voce in lista:
