                        else:
                            bmr = (10 * p) + (6.25 * a) - (5 * e) - 161
                        fabbisogni = {
                            "Sedentario (Ufficio)":    round(bmr * 1.2),
                            "Leggero (Attività 1-2v)": round(bmr * 1.375),
