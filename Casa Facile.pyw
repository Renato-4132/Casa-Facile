def leggi_configurazione_globale():
    p_locale = os.path.dirname(os.path.abspath(__file__))
    c_file = os.path.join(p_locale, "db", "config.json")
    try:
        if os.path.exists(c_file):
            with open(c_file, 'r', encoding='utf-8') as f:
                return json.load(f)
    except:
        pass
    return {}
    
