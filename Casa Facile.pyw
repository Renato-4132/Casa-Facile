            def salva_modifica():
                try:
                    data_obj = datetime.strptime(data_e_var.get(), "%d-%m-%Y").date()
                    data_ggmmaaaa = data_obj.strftime("%d%m%Y")
                    imp_pulito = imp_e_var.get().replace(".", "").replace(",", ".")
                    imp_dec = Decimal(imp_pulito)
