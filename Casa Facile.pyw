                         fg=colore or self.TEXT_COLOR).pack(pady=(2, 8))
            def fmt(v):
                return f"€ {v:,.2f}".replace(",", "X").replace(".", ",").replace("X", ".")
            def fmt_pct(v):
                return f"{v:+.2f}%"
            pl_color = self.COLOR_GREEN if pl_tot >= 0 else self.COLOR_RED
