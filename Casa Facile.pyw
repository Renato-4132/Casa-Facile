                b = tk.Label(frm_act, text=testo, image=img, compound="left",
                             bg=self.COLOR_WIDGET_BG, fg=self.TEXT_COLOR,
                             font=("Segoe UI", 10, "bold"), cursor="hand2",
                             padx=15, pady=8)
                b.image = img
                b.pack(side="left", padx=6)
                b.bind("<Button-1>", lambda e, c=cmd: c())    
