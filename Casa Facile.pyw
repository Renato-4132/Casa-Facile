                    _tx(page, "Piano indicativo. Consultare un nutrizionista per esigenze specifiche.",
                        ML, fy + 6, fs=7, col=GRAY)
                    _tx(page, f"Pag. {len(piano_dati) + 1}/{len(piano_dati) + 1}",
                        PAGE_W - MR - 40, fy + 6, fs=7, col=GRAY)
                try:
                    s = inputs["Sesso"].get()
