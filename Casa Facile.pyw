            foreground="black",
            font=("Arial", 10, "bold"),
            anchor="center"
        )
        b2.image = self.icone_gui.get("chiudi")
        b2.grid(row=0, column=1, padx=5, sticky="nsew")
        b2.bind("<Button-1>", lambda e: do_cancel())
