                lbl_det.insert("end", f"{dov:>11,.2f} €  ", "giallo")
                lbl_det.insert("end", f"{ver:>11,.2f} €  ", "verde")
                lbl_det.insert("end", f"{res:>11,.2f} €  ", sal_tag)
