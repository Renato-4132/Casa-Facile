                    imp_raw = str(int(imp_dec * 100))
                except Exception:
                    self.show_toast("Dati non validi.")
                desc_pulita = desc_e_var.get().strip()
                while desc_pulita.startswith('📎'):
                    desc_pulita = desc_pulita[len('📎'):].strip()
