                righe_vars = []
                def _upd_subtot(dv, qv, pv, iv, sv):
                    try:
                        q = float(qv.get().replace(",",".") or 0)
                        p = float(pv.get().replace(",",".") or 0)
                        i = float(iv.get() or 0)
                        sv.set(f"{q*p*(1+i/100):.2f}")
                    except Exception:
                        sv.set("0.00")
                def _add_riga(desc="", qty=1, prezzo=0.0, iva=22, elim=True):
                    r = len(righe_vars) + 1
                    dv = tk.StringVar(value=str(desc))
                    qv = tk.StringVar(value=str(qty))
                    pv = tk.StringVar(value=str(prezzo))
                    iv = tk.StringVar(value=str(iva))
                    sv = tk.StringVar(value="0.00")
                    for var in (dv, qv, pv, iv):
                        var.trace_add("write",
                                      lambda *_, d=dv,q=qv,p=pv,i=iv,s=sv:
                                      _upd_subtot(d,q,p,i,s))
                    ttk.Entry(rig_frame, textvariable=dv, width=25).grid(
                        row=r, column=0, padx=2, pady=1)
                    ttk.Entry(rig_frame, textvariable=qv, width=6).grid(
                        row=r, column=1, padx=2, pady=1)
                    ttk.Entry(rig_frame, textvariable=pv, width=9).grid(
                        row=r, column=2, padx=2, pady=1)
                    cb_i = ttk.Combobox(rig_frame, textvariable=iv,
