            ttk.Label(frm_top, text="Descrizione:").grid(row=0, column=5, sticky="e", padx=4, pady=3)
            entry_desc = ttk.Entry(frm_top, width=28)
            entry_desc.grid(row=0, column=6, sticky="w", padx=4, pady=3)
            def val_desc(v): return len(v) <= 30
