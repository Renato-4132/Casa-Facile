            inn.pack(expand=True)
            gemini_colors = ["#0055FF", "#AA00FF", "#FF0055", "#00C853"]
            cvs_sz = 28
            cvs2 = tk.Canvas(inn, width=cvs_sz, height=cvs_sz,
