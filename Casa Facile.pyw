                                      background=self.COLOR_WIDGET_BG)
                    if img_d: lbl_d.image = img_d
                    lbl_d.grid(row=r, column=5, padx=2, pady=1)

                    rv = (dv, qv, pv, iv)
                    righe_vars.append(rv)
                    def _rimuovi(rv=rv, lbl=lbl_d):
                        righe_vars.remove(rv)
                        for widget in rig_frame.grid_slaves(row=r):
                            widget.destroy()
                    lbl_d.bind("<Button-1>", lambda e, rm=_rimuovi: rm())
                    _upd_subtot(dv, qv, pv, iv, sv)
                righe_src = (prefill or {}).get("righe",
                    [{"desc":"","qty":1,"prezzo":0.0,"iva":22}])
                for rig in righe_src:
                    _add_riga(rig.get("desc",""), rig.get("qty",1),
                              rig.get("prezzo",0.0), rig.get("iva",22))
                tipo_doc = (prefill or {}).get("tipo_doc","Fattura")
                tipo_var.set(tipo_doc)
                e_num.insert(0, (prefill or {}).get("numero",
                               _next_num(tipo_doc)))
                def _to_dmy(s):
                    if s and len(s)==10 and "-" in s:
                        return s[8:]+"/"+s[5:7]+"/"+s[:4]
                    return s or ""
                e_dat.insert(0, _to_dmy((prefill or {}).get("data",
                               datetime.datetime.now().strftime("%Y-%m-%d"))))
                e_sca.insert(0, _to_dmy((prefill or {}).get("scadenza","")))
                e_cli.set(      (prefill or {}).get("cliente_nome",""))
                e_stato.set(    (prefill or {}).get("stato","Bozza"))
                e_note.insert(0,(prefill or {}).get("note",""))
                def _on_tipo_change(e=None):
                    t = tipo_var.get()
                    if not (prefill):
                        e_num.delete(0,"end")
                        e_num.insert(0, _next_num(t))
                e_tipo.bind("<<ComboboxSelected>>", _on_tipo_change)
                bot = tk.Frame(fw, bg=self.COLOR_WIDGET_BG)
                bot.grid(row=8, column=0, columnspan=4, pady=6)
                img_add = self.icone_gui.get("aggiungi")
                b_add = ttk.Label(bot, text=" + Riga", image=img_add,
                                  compound="left",
                                  background=self.COLOR_WIDGET_BG,
                                  cursor="hand2", font=("Arial",9,"bold"),
                                  padding=(6,3))
                if img_add: b_add.image = img_add
                b_add.pack(side="left", padx=8)
                b_add.bind("<Button-1>", lambda e: _add_riga())
                def _salva():
                    righe = []
                    for dv,qv,pv,iv in righe_vars:
                        desc = dv.get().strip()
                        if not desc: continue
                        try:    q = float(qv.get().replace(",",".") or 1)
                        except: q = 1
                        try:    p = float(pv.get().replace(",",".") or 0)
                        except: p = 0
                        try:    i = int(iv.get() or 22)
                        except: i = 22
                        righe.append({"desc":desc,"qty":q,"prezzo":p,"iva":i})
                    def _parse(s):
                        try: return datetime.datetime.strptime(s.strip(), "%d/%m/%Y").strftime("%Y-%m-%d")
                        except: return s.strip()
                    record = {
                        "id":           prefill["id"] if prefill else _new_id(),
                        "tipo_doc":     tipo_var.get() or "Fattura",
                        "numero":       e_num.get().strip() or _next_num(tipo_var.get()),
                        "data":         _parse(e_dat.get()),
                        "scadenza":     _parse(e_sca.get()) if e_sca.get().strip() else "",
                        "cliente_nome": e_cli.get().strip(),
                        "righe":        righe,
                        "stato":        e_stato.get().strip() or "Bozza",
                        "note":         e_note.get().strip(),
                    }
                    if prefill:
                        idx = next((i for i,f in enumerate(fatture)
                                    if f["id"]==prefill["id"]), None)
                        if idx is not None: fatture[idx] = record
                    else:
                        fatture.append(record)
                    _save(STUDIO_FATTURE, fatture)
                    _refresh(record["id"])
                    fw.destroy()
                    self.show_toast("Documento salvato.")
                img_s = self.icone_gui.get("salva")
                b_salva = ttk.Label(bot, text=" Salva", image=img_s,
                                    compound="left",
                                    background=self.COLOR_WIDGET_BG,
                                    cursor="hand2", font=("Arial",9,"bold"),
                                    padding=(6,3))
                if img_s: b_salva.image = img_s
                b_salva.pack(side="left", padx=8)
                b_salva.bind("<Button-1>", lambda e, c=_salva: c())
                fw.bind("<Escape>", lambda e: fw.destroy())
                img_ch = self.icone_gui.get("chiudi")
                b_ch = ttk.Label(bot, text=" Chiudi", image=img_ch,
                                 compound="left",
                                 background=self.COLOR_WIDGET_BG,
                                 cursor="hand2", font=("Arial",9,"bold"),
                                 padding=(6,3))
                if img_ch: b_ch.image = img_ch
                b_ch.pack(side="left", padx=8)
                b_ch.bind("<Button-1>", lambda e: fw.destroy())
            def _genera_pdf(doc=None):
                if doc is None:
                    sel = tv.selection()
                    if not sel:
                        self.show_toast("Seleziona un documento."); return
                    doc = next((f for f in fatture if f["id"]==sel[0]), None)
                    if not doc: return
                nome_cli = doc.get("cliente_nome","")
                cli_rec  = next((c for c in clienti
                                 if f"{c.get('nome','')} {c.get('cognome','')}".strip() == nome_cli
                                 or c.get("azienda","") == nome_cli), {})
                try:
                    import fitz
                except ImportError:
                    self.show_custom_warning("Errore",
                        "PyMuPDF (fitz) non installato.\n"
                        "Installa con: pip install pymupdf"); return
                path_out = filedialog.asksaveasfilename(
                    parent=win,
                    initialdir=EXPORT_DIR,
                    defaultextension=".pdf",
                    filetypes=[("PDF","*.pdf")],
                    initialfile=f"{doc.get('tipo_doc','Doc')}_{doc.get('numero','').replace('/','_')}.pdf",
                    confirmoverwrite=True
                )
                if not path_out: return
                try:
                    pdoc = fitz.open()
                    W_PDF, H_PDF = 595, 842
                    page = pdoc.new_page(width=W_PDF, height=H_PDF)
                    MARG = 40
                    y    = MARG
                    C_BLU   = (0.12, 0.36, 0.62)
                    C_GREY  = (0.85, 0.85, 0.85)
                    C_BLACK = (0, 0, 0)
                    C_WHITE = (1, 1, 1)
                    C_RED   = (0.75, 0.1, 0.1)
                    C_GREEN_D = (0.1, 0.5, 0.2)
                    def _txt(x, y, testo, size=9, color=C_BLACK, bold=False):
                        fn = "Helvetica-Bold" if bold else "Helvetica"
                        page.insert_text((x, y), testo, fontname=fn,
                                         fontsize=size, color=color)
                    def _rect(x0, y0, x1, y1, fill=None, stroke=None, lw=0.5):
                        page.draw_rect(fitz.Rect(x0, y0, x1, y1),
                                       color=stroke, fill=fill,
                                       width=lw)
                    def _line(x0, y0, x1, y1, color=C_GREY, lw=0.5):
                        page.draw_line((x0,y0),(x1,y1), color=color, width=lw)
                    _rect(0, 0, W_PDF, 72, fill=C_BLU)
                    logo_path = emittente.get("logo_path", "")
                    if logo_path and os.path.isfile(logo_path):
                        try:
                            logo_rect = fitz.Rect(W_PDF - 100, 6, W_PDF - 8, 66)
                            page.insert_image(logo_rect, filename=logo_path,
                                              keep_proportion=True)
                        except Exception:
                            pass
                    tipo_doc = doc.get("tipo_doc","Fattura").upper()
                    _txt(MARG, 26, tipo_doc, size=20, color=C_WHITE, bold=True)
                    num = doc.get("numero","")
                    _txt(MARG, 44, f"N°  {num}", size=11, color=C_WHITE)
                    try: df = datetime.date.fromisoformat(doc["data"]).strftime("%d/%m/%Y")
                    except: df = doc.get("data","")
                    _txt(W_PDF-260, 26, f"Data: {df}", size=9, color=C_WHITE)
                    sc = doc.get("scadenza","")
                    if sc:
                        try: sc = datetime.date.fromisoformat(sc).strftime("%d/%m/%Y")
                        except: pass
                        _txt(W_PDF-260, 40, f"Scadenza: {sc}", size=9, color=C_WHITE)
                    y = 90
                    mid = W_PDF // 2 + 10
                    _txt(MARG, y, "EMESSO DA", size=7, color=C_BLU, bold=True)
                    _txt(mid,  y, "DESTINATARIO", size=7, color=C_BLU, bold=True)
                    y += 12
                    emi_lines = [
                        emittente.get("ragione_sociale", "[Nome / Ragione Sociale]"),
                        emittente.get("indirizzo",       "[Indirizzo]"),
                        emittente.get("cf_piva",         "[P.IVA / CF]"),
                        " | ".join(filter(None, [
                            emittente.get("telefono", ""),
                            emittente.get("email", ""),
                        ])) or "[Tel. / Email]",
                    ]
                    for riga in emi_lines:
                        col = (0.5, 0.5, 0.5) if riga.startswith("[") else C_BLACK
                        _txt(MARG, y, riga, size=8, color=col)
                        y += 12
                    y_c = 102
                    cli_lines = [
                        cli_rec.get("azienda","") or nome_cli,
                        cli_rec.get("indirizzo",""),
                        cli_rec.get("cf_piva",""),
                        cli_rec.get("email","") or cli_rec.get("telefono",""),
                    ]
                    for rl in cli_lines:
                        if rl:
                            _txt(mid, y_c, rl, size=9)
                        y_c += 12
                    y = max(y, y_c) + 10
                    _line(MARG, y, W_PDF-MARG, y, color=C_BLU, lw=1)
                    y += 10
                    COL_X = [MARG, MARG+250, MARG+300, MARG+360, MARG+410]
                    COL_HDR = ["Descrizione","Qtà","Prezzo €","IVA %","Importo €"]
                    _rect(MARG, y, W_PDF-MARG, y+16, fill=C_BLU)
                    for cx, hdr in zip(COL_X, COL_HDR):
                        _txt(cx+3, y+11, hdr, size=8, color=C_WHITE, bold=True)
                    y += 18
                    righe = doc.get("righe",[])
                    tot_imponibile = 0.0
                    tot_iva        = {}
                    for i, rig in enumerate(righe):
                        desc  = rig.get("desc","")
                        qty   = rig.get("qty",1)
                        prez  = rig.get("prezzo",0.0)
                        iva_r = rig.get("iva",22)
                        imp   = qty * prez
                        iva_v = imp * iva_r / 100
                        sub   = imp + iva_v
                        tot_imponibile += imp
                        tot_iva[iva_r] = tot_iva.get(iva_r,0) + iva_v
                        bg = C_GREY if i % 2 == 0 else C_WHITE
                        _rect(MARG, y, W_PDF-MARG, y+14, fill=bg)
                        desc_s = desc[:45] + "…" if len(desc) > 45 else desc
                        _txt(COL_X[0]+3, y+10, desc_s,    size=8)
                        _txt(COL_X[1]+3, y+10, str(qty),  size=8)
                        _txt(COL_X[2]+3, y+10, f"{prez:.2f}", size=8)
                        _txt(COL_X[3]+3, y+10, f"{iva_r}%",   size=8)
                        _txt(COL_X[4]+3, y+10, f"{sub:.2f}",  size=8)
                        y += 14
                        if y > H_PDF - 160:
                            page2 = pdoc.new_page(width=W_PDF, height=H_PDF)
                            page  = page2
                            y     = MARG
                    y += 6
                    _line(MARG, y, W_PDF-MARG, y, color=C_BLU, lw=1)
                    y += 10
                    tot_iva_tot = sum(tot_iva.values())
                    tot_totale  = tot_imponibile + tot_iva_tot
                    riepilogo = [
                        ("Imponibile", tot_imponibile),
                    ] + [(f"IVA {al}%", v) for al,v in sorted(tot_iva.items())] + [
                        ("TOTALE", tot_totale),
                    ]
                    box_x = W_PDF - MARG - 160
                    for label, valore in riepilogo:
                        is_tot = label == "TOTALE"
                        if is_tot:
                            _rect(box_x-4, y-2, W_PDF-MARG, y+14,
                                  fill=C_BLU)
                            _txt(box_x, y+10, label, size=9, color=C_WHITE, bold=True)
                            _txt(box_x+80, y+10, _fmt_eur(valore),
                                 size=9, color=C_WHITE, bold=True)
                        else:
                            _txt(box_x, y+10, label, size=8)
                            _txt(box_x+80, y+10, _fmt_eur(valore), size=8)
                        y += 16
                    y += 10
                    stato = doc.get("stato","")
                    if stato:
                        col_stato = C_GREEN_D if stato=="Pagata" else \
                                    C_RED if stato in ("Scaduta","Annullata") else C_BLU
                        _txt(MARG, y, f"Stato: {stato}", size=9,
                             color=col_stato, bold=True)
                        y += 14
                    note = doc.get("note","")
                    if note:
                        y += 4
                        _txt(MARG, y, "Note:", size=8, bold=True)
                        y += 12
                        parole = note.split()
                        riga_note = ""
                        for p in parole:
                            if len(riga_note) + len(p) + 1 > 90:
                                _txt(MARG, y, riga_note, size=8)
                                y += 12; riga_note = p
                            else:
                                riga_note += (" " + p) if riga_note else p
                        if riga_note:
                            _txt(MARG, y, riga_note, size=8)
                    _rect(0, H_PDF-28, W_PDF, H_PDF, fill=C_BLU)
                    _txt(MARG, H_PDF-12,
                         "Vi ringraziamo per la preferenza accordataci",
                         size=7, color=C_WHITE)
                    oggi_str = datetime.date.today().strftime("%d/%m/%Y")
                    _txt(W_PDF-120, H_PDF-12,
                         f"Stampato il {oggi_str}",
                         size=7, color=C_WHITE)
                    pdoc.save(path_out)
                    pdoc.close()
                    self.show_toast("✅ PDF salvato.")
                    try:
                        if sys.platform == "win32":
                            os.startfile(path_out)
                        elif sys.platform == "darwin":
                            subprocess.Popen(["open", path_out])
                        else:
                            subprocess.Popen(["xdg-open", path_out])
                    except Exception:
                        pass
                except Exception as e:
                    self.show_custom_warning("Errore PDF", str(e))
            def _stampa_diretta():
                sel = tv.selection()
                if not sel:
                    self.show_toast("Seleziona un documento."); return
                doc = next((f for f in fatture if f["id"]==sel[0]), None)
                if not doc: return
                import tempfile
                tmp = tempfile.NamedTemporaryFile(suffix=".pdf", delete=False)
                tmp.close()
                _genera_pdf_path(doc, tmp.name)
            def _genera_pdf_path(doc, path_out):
                try:
                    import fitz
                    sel_orig = tv.selection()
                    _genera_pdf(doc=doc)
                except Exception:
                    pass
            def _modifica():
                sel = tv.selection()
                if not sel: self.show_toast("Seleziona un documento."); return
                r = next((f for f in fatture if f["id"]==sel[0]), None)
                if r: _form(prefill=r)
            def _elimina():
                sel = tv.selection()
                if not sel: self.show_toast("Seleziona un documento."); return
                if self.show_custom_askyesno("Elimina", "Eliminare il documento selezionato?"):
                    nonlocal fatture
                    fatture = [f for f in fatture if f["id"]!=sel[0]]
                    _save(STUDIO_FATTURE, fatture)
                    _refresh()
                    self.show_toast("Eliminato.")
            tv.bind("<Double-1>", lambda e: _modifica())
            _btn_bar(tab_fat, [
                ("aggiungi", "Nuovo",        lambda: _form(),  self.COLOR_GREEN),
                ("modifica", "Modifica",     _modifica,        self.COLOR_HIGHLIGHT),
                ("report",   "Salva PDF",    _genera_pdf,      self.TEXT_COLOR),
                ("stampa",   "Stampa",       lambda: _genera_pdf(), self.TEXT_COLOR),
                ("delete",   "Elimina",      _elimina,         self.COLOR_RED),
            ])
            _refresh()
        def _build_cassa():
            for w in tab_cas.winfo_children(): w.destroy()
            top = tk.Frame(tab_cas, bg=self.COLOR_BACKGROUND)
            top.pack(fill="x", padx=8, pady=(6,2))
            lbl_saldo = tk.Label(top, text="Saldo: € 0,00",
                                 font=("Arial",11,"bold"),
                                 bg=self.COLOR_BACKGROUND,
                                 fg=self.TEXT_COLOR)
            lbl_saldo.pack(side="left")
            lbl_in  = tk.Label(top, text="", font=("Arial",9),
                               bg=self.COLOR_BACKGROUND,
                               fg=self.COLOR_GREEN)
            lbl_in.pack(side="left", padx=14)
            lbl_out = tk.Label(top, text="", font=("Arial",9),
                               bg=self.COLOR_BACKGROUND,
                               fg=self.COLOR_RED)
            lbl_out.pack(side="left")
            cols   = ["Data","Tipo","Importo €","Categoria","Metodo Pag.","Note"]
            widths = [90, 80, 90, 140, 110, 300]
            tv = _tree(tab_cas, cols, widths)
            def _refresh(sel_id=None):
                tv.delete(*tv.get_children())
                saldo = entrate = uscite = 0.0
                for m in sorted(cassa, key=lambda x: x.get("data","")):
                    imp  = m.get("importo",0.0)
                    tipo = m.get("tipo","Entrata")
                    if tipo == "Entrata":
                        saldo += imp; entrate += imp
                    else:
                        saldo -= imp; uscite  += imp
                    tag = "verde" if tipo=="Entrata" else "rosso"
                    try: df = datetime.date.fromisoformat(m["data"]).strftime("%d/%m/%Y")
                    except: df = m.get("data","")
                    tv.insert("", "end", iid=m["id"], tags=(tag,),
                              values=(df, tipo, _fmt_eur(imp),
                                      m.get("categoria",""),
                                      m.get("metodo",""),
                                      m.get("note","")))
                tv.tag_configure("verde", foreground=self.COLOR_GREEN)
                tv.tag_configure("rosso", foreground=self.COLOR_RED)
                col = self.COLOR_GREEN if saldo>=0 else self.COLOR_RED
                lbl_saldo.config(text=f"Saldo: {_fmt_eur(saldo)}", fg=col)
                lbl_in.config(text=f"↑ Entrate: {_fmt_eur(entrate)}")
                lbl_out.config(text=f"↓ Uscite: {_fmt_eur(uscite)}")
                if sel_id:
                    try: tv.selection_set(sel_id); tv.see(sel_id)
                    except Exception: pass
            def _form(prefill=None):
                fw = _form_win("Movimento Cassa", 400)
                fw.columnconfigure(1, weight=1)
                _titulo(fw,"Modifica" if prefill else "➕ Nuovo movimento")
                _row(fw,"Data (GG/MM/AAAA) *",1)
                frm_d = tk.Frame(fw, bg=self.COLOR_WIDGET_BG)
                frm_d.grid(row=1, column=1, sticky="w", padx=10, pady=3)
                e_data = ttk.Entry(frm_d, width=12)
                e_data.pack(side="left")
                _mk_cal_btn(frm_d, e_data)
                _row(fw,"Tipo",               2)
                e_tipo = _cbo(fw,2,["Entrata","Uscita"],width=12)
                _row(fw,"Importo €",          3); e_imp  = _ent(fw,3,width=12)
                _row(fw,"Categoria",          4); e_cat  = _ent(fw,4)
                _row(fw,"Metodo Pagamento",   5)
                e_met = _cbo(fw,5,["Contanti","Bonifico","Carta","POS","Assegno","Altro"],width=14)
                _row(fw,"Note",               6); e_note = _ent(fw,6)
                if prefill:
                    d = prefill.get("data","")
                    if d and "-" in d: d = d[8:]+"/"+d[5:7]+"/"+d[:4]
                    e_data.insert(0, d)
                    e_tipo.set(    prefill.get("tipo","Entrata"))
                    e_imp.insert(0,str(prefill.get("importo","")))
                    e_cat.insert(0,prefill.get("categoria",""))
                    e_met.set(    prefill.get("metodo",""))
                    e_note.insert(0,prefill.get("note",""))
                else:
                    e_data.insert(0, datetime.datetime.now().strftime("%d/%m/%Y"))
                    e_tipo.set("Entrata")
                def _salva():
                    data_raw = e_data.get().strip()
                    if not data_raw: self.show_toast("Data obbligatoria."); return
                    try:
                        data = datetime.datetime.strptime(data_raw, "%d/%m/%Y").strftime("%Y-%m-%d")
                    except ValueError:
                        self.show_toast("Data non valida (GG/MM/AAAA)."); return
                    try: imp = float(e_imp.get().replace(",",".") or 0)
                    except: self.show_toast("Importo non valido."); return
                    record = {
                        "id":        prefill["id"] if prefill else _new_id(),
                        "data":      data,
                        "tipo":      e_tipo.get().strip() or "Entrata",
                        "importo":   imp,
                        "categoria": e_cat.get().strip(),
                        "metodo":    e_met.get().strip(),
                        "note":      e_note.get().strip(),
                    }
                    if prefill:
                        idx = next((i for i,m in enumerate(cassa)
                                    if m["id"]==prefill["id"]),None)
                        if idx is not None: cassa[idx] = record
                    else:
                        cassa.append(record)
                    _save(STUDIO_CASSA, cassa)
                    _refresh(record["id"])
                    fw.destroy()
                    self.show_toast("Movimento salvato.")
                fw.bind("<Escape>", lambda e: fw.destroy())
                bot = tk.Frame(fw, bg=self.COLOR_BACKGROUND)
                bot.grid(row=7, column=0, columnspan=4, pady=8)
                _mk_btn(bot, "salva",  "Salva",  _salva)
                _mk_btn(bot, "chiudi", "Chiudi", fw.destroy)
            def _modifica():
                sel = tv.selection()
                if not sel: self.show_toast("Seleziona un movimento."); return
                r = next((m for m in cassa if m["id"]==sel[0]), None)
                if r: _form(prefill=r)
            def _elimina():
                sel = tv.selection()
                if not sel: self.show_toast("Seleziona un movimento."); return
                if self.show_custom_askyesno("Elimina","Eliminare il movimento selezionato?"):
                    nonlocal cassa
                    cassa = [m for m in cassa if m["id"]!=sel[0]]
                    _save(STUDIO_CASSA, cassa)
                    _refresh()
                    self.show_toast("Eliminato.")
            tv.bind("<Double-1>", lambda e: _modifica())
            _btn_bar(tab_cas, [
                ("aggiungi","Nuovo",   lambda: _form(), self.COLOR_GREEN),
                ("modifica","Modifica",_modifica,       self.COLOR_HIGHLIGHT),
                ("delete",  "Elimina", _elimina,        self.COLOR_RED),
            ])
            _refresh()
