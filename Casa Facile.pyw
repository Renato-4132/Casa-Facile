        self.lbl_importo.grid(row=row, column=0, sticky="e", padx=2, pady=2)

        def convalida_importo(valore):
            if valore == "":
              return True  
            import re
            return len(valore) <= 7 and re.fullmatch(r"^\d*[.,]?\d{0,2}$", valore) is not None
