                f, from_=min_val, to=max_val, 
                variable=variable, 
                command=update_func, 
                orient='horizontal'
            )
            slider.grid(row=0, column=1, sticky="ew", padx=10)
            f.columnconfigure(1, weight=1)
            label_obj.lift() 
