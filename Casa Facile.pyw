        def aggiorna_tabella(*_args):
            tree_a.delete(*tree_a.get_children())
            p_sel  = cb_part.get()
            if p_sel not in ("", "Tutti") and " " in p_sel:
                p_sel = p_sel.split(" ", 1)[1].strip()
